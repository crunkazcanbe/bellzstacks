#!/bin/bash

# ── Lock to prevent duplicate runs ───────────────────────────────────────────
touch /tmp/docker-stacks-up.lock 2>/dev/null || true
chmod 666 /tmp/docker-stacks-up.lock 2>/dev/null || true
exec 200>/tmp/docker-stacks-up.lock
flock -n 200 || { echo "Already running. Exiting."; exit 0; }

export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
LOG=/var/log/docker-stacks-up.log
WATCHDOG_LOG=/var/log/docker-watchdog.log
STACKS_CMD=/usr/local/bin/stacks
BOOT_MODE=$(python3 -c "import json,os; d=json.load(open(os.path.expanduser('~/.config/stacks/menu.conf'))) if os.path.exists(os.path.expanduser('~/.config/stacks/menu.conf')) else {}; print(d.get('boot_mode','stacks'))" 2>/dev/null || echo "stacks")
export TERM=dumb
export NO_TTY=1
STACKS_DIR=/srv/stacks/Stacks
STACKS=(core_0 core_1 core_2 core_3 net_0 net_2 db_0 db_2 net_3 db_1 db_3 db_4 db_5 db_6 net_1 net_3 ai_0 ai_1 ai_2 ai_3 srvs_0 srvs_1 srvs_2 dev_0 dev_1 dev_2 dev_3 dev_4 data_0 data_1)

CRITICAL_SITES=(
    "traefik.example.com"
    "sablier.example.com"
    "auth.example.com"
    "authentik.example.com"
    "crowdsec.example.com"
)

exec > >(tee -a "$LOG") 2>&1

log() { echo "[$(date '+%H:%M:%S')] $*"; }

log "=== docker-stacks-up started ==="

# ── Exit early if already healthy ────────────────────────────────────────────
TRAEFIK_HTTP=$(/usr/bin/curl -sk -o /dev/null -w "%{http_code}" --max-time 5 https://traefik.example.com 2>/dev/null)
RUNNING=$(docker ps -q 2>/dev/null | wc -l)
if [[ "$TRAEFIK_HTTP" =~ ^(200|301|302|401|403)$ ]] && [ "$RUNNING" -gt 100 ]; then
    log "=== System healthy (Traefik HTTP $TRAEFIK_HTTP, $RUNNING containers running). Exiting. ==="
    exit 0
fi
log "=== System needs recovery (Traefik HTTP $TRAEFIK_HTTP, $RUNNING running). Proceeding... ==="

# ── Wait for docker-direct network ──────────────────────────────────────────
log "=== Waiting for docker-direct service ==="
for i in $(seq 1 30); do
    if /bin/systemctl is-active --quiet docker-direct.service 2>/dev/null; then
        log "docker-direct ready after ${i}*2s"
        break
    fi
    sleep 2
done

# ── Wait for OPNSense ─────────────────────────────────────────────────────────
log "=== Waiting for OPNSense at 192.168.151.2 ==="
for i in $(seq 1 30); do
    if ping -c 1 -W 2 192.168.151.2 >/dev/null 2>&1; then
        echo "OPNSense reachable after ${i}*10s"
        break
    fi
    sleep 10
done

# ── Wait for Docker ───────────────────────────────────────────────────────────
log "=== Waiting for docker daemon ==="
for i in $(seq 1 30); do
    if docker info >/dev/null 2>&1; then
        echo "Docker ready after ${i}*2s"
        break
    fi
    sleep 2
done

# ── Deploy each stack ─────────────────────────────────────────────────────────
log "=== Deploying all stacks (mode: $BOOT_MODE) ==="
for stack in "${STACKS[@]}"; do
    log "--- Stack: $stack ---"

    if [ "$BOOT_MODE" = "docker" ]; then
        # EMERGENCY DOCKER MODE — raw docker compose only
        docker compose -f "$STACKS_DIR/$stack.yml" pull --ignore-pull-failures >> "$LOG" 2>&1 || true
        docker compose -f "$STACKS_DIR/$stack.yml" up -d >> "$LOG" 2>&1 && log "  -> $stack OK (docker)" || log "  -> $stack FAILED (docker)"
    else
        # STACKS MODE — full recovery sequence
        # Pull missing images first so pruned images get re-downloaded
        docker compose -f "$STACKS_DIR/$stack.yml" pull --ignore-pull-failures >> "$LOG" 2>&1 || true

        # Step 1: Simple up
        if $STACKS_CMD up "$stack" >> "$LOG" 2>&1; then
            log "  -> $stack OK"
            continue
        fi

        # Step 2: Recreate
        log "  -> $stack failed, trying recreate..."
        if $STACKS_CMD up "$stack" recreate >> "$LOG" 2>&1; then
            log "  -> $stack OK (recreate)"
            continue
        fi

        # Step 3: Recreate + repair
        log "  -> $stack failed recreate, trying repair..."
        if $STACKS_CMD up "$stack" recreate repair >> "$LOG" 2>&1; then
            log "  -> $stack OK (repair)"
            continue
        fi

        # Step 4: Fix (ABSOLUTE LAST RESORT — applies config + repairs)
        log "  -> $stack failed repair, LAST RESORT: fix repair recreate..."
        if $STACKS_CMD up "$stack" recreate repair fix >> "$LOG" 2>&1; then
            log "  -> $stack OK (fix last-resort)"
            continue
        fi

        log "  -> $stack FAILED all attempts, continuing..."
    fi
done

log "=== All stacks attempted. Restarting critical services... ==="

# ── Restart critical containers ───────────────────────────────────────────────
for crit in traefik sablier cloudflared_tunnel_core authentik-server crowdsec; do
    log "  -> Restarting $crit..."
    docker restart "$crit" 2>/dev/null || true
done
sleep 30

# ── Check site reachability and restart containers if needed ──────────────────
log "=== Checking site reachability ==="
for attempt in 1 2 3; do
    ALL_OK=1
    for site in "${CRITICAL_SITES[@]}"; do
        code=$(/usr/bin/curl -sk -o /dev/null -w "%{http_code}" --max-time 8 "https://${site}" 2>/dev/null)
        if [[ "$code" =~ ^(200|301|302|401|403)$ ]]; then
            echo "  ✔ $site reachable (HTTP $code)"
        else
            echo "  ✖ $site UNREACHABLE (HTTP ${code:-timeout}) — restarting related container..."
            ALL_OK=0
            # Restart the container matching the site name
            cname=$(echo "$site" | cut -d. -f1)
            case "$cname" in
                traefik)    docker restart traefik 2>/dev/null || true ;;
                sablier)    docker restart sablier 2>/dev/null || true ;;
                auth)       docker restart authelia 2>/dev/null || true ;;
                authentik)  docker restart authentik-server 2>/dev/null || true ;;
                crowdsec)   docker restart crowdsec crowdsec-bouncer 2>/dev/null || true ;;
            esac
        fi
    done

    if [ "$ALL_OK" -eq 1 ]; then
        log "=== All critical sites reachable! ==="
        break
    fi

    if [ "$attempt" -lt 3 ]; then
        log "=== Attempt $attempt/3 — waiting 30s before retry... ==="
        sleep 30
    else
        log "=== Attempt 3/3 — some sites still unreachable. Watchdog will handle recovery. ==="
    fi
done

log "=== Waiting 5 minutes for Sablier to initialize and sleep containers... ==="
for i in $(seq 300 -1 1); do
    if [ $((i % 30)) -eq 0 ]; then
        log "  ... $i seconds remaining ..."
    fi
    sleep 1
done
log "=== Starting watchdog services... ==="
/bin/systemctl start docker-watchdog.service 2>/dev/null || true
/bin/systemctl start docker-stacks-watchdog.service 2>/dev/null || true
log "=== docker-stacks-up complete: $(date) ==="

exit 0
